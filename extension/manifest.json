{
  "manifest_version": 3,
  "name": "Trucking Lane — Leads & Aljex Spot Submit",
  "version": "1.2.0",
  "description": "AI lead notifications and automatic Aljex spot load submission for TruckingLanes.",
  "permissions": ["notifications", "alarms", "storage", "tabs", "webRequest", "cookies"],
  "host_permissions": [
    "https://vjgakkomhphvdbwjjwiv.supabase.co/*",
    "https://dandl.aljex.com/*",
    "http://187.77.217.123:3098/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://dandl.aljex.com/route.php*"],
      "js": ["aljex-spot-injector.js"],
      "run_at": "document_idle"
    }
  ]
}
